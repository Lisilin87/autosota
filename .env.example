# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1

# Anthropic API Configuration (optional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Docker Configuration
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_TIMEOUT=3600

# GPU Configuration
CUDA_VISIBLE_DEVICES=0
GPU_MEMORY_FRACTION=0.9

# LLM Configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3

# System Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
WORKSPACE_ROOT=./workspaces
MAX_ITERATIONS=8

# Scheduler Configuration
MAX_PARALLEL_TASKS=2
CHECKPOINT_INTERVAL=60
RECOVERY_ENABLED=true

# Monitor Configuration
STUCK_TIMEOUT=1200
REPEATED_ERROR_THRESHOLD=3
LOG_CHECK_INTERVAL=10

# Docker Runtime Configuration
DOCKER_ENABLED=true
DOCKER_BASE_IMAGE=pytorch/pytorch:2.2.0-cuda12.1-cudnn8-runtime
DOCKER_GPU_ENABLED=true
DOCKER_MEMORY_LIMIT=16g
DOCKER_SHM_SIZE=8g

# Resource Configuration
SHALLOW_CLONE=true
MAX_DOWNLOAD_GB=50
REPO_SEARCH_TIMEOUT=300
READINESS_CHECK_ENABLED=true

# Objective Configuration
RUBRIC_MAX_DEPTH=3
RUBRIC_WEIGHT_THRESHOLD=0.1
PRIMARY_METRIC_REQUIRED=true
SECONDARY_METRICS_REQUIRED=true

# Supervisor Configuration
REDLINE_POLICY=configs/policies/redlines.yaml
STRICT_MODE=true
AUDIT_ALL_IDEAS=true

# Evaluation Configuration
PRIMARY_METRIC_REQUIRED=true
SECONDARY_METRICS_REQUIRED=true
BASELINE_REQUIRED=true
METRIC_PARSE_TIMEOUT=60
